# ── Catenaccio environment ──────────────────────────────────────────────────
# The dashboard + demo run with ZERO config (deterministic replay, simulated
# on-chain verification). Fill these in only to point at the LIVE TxLINE feed
# and a real Solana devnet wallet. Never commit a filled-in .env.

# TxLINE (TxODDS) — leave blank to use the bundled replay.
# With JWT + API token set, `npm run live` streams the real odds + scores SSE feed.
TXLINE_AUTH_URL=https://txline.txodds.com
TXLINE_API_URL=https://txline-dev.txodds.com/api
TXLINE_JWT=
TXLINE_API_TOKEN=
# Optional: pin `npm run live` to one fixture (defaults to the first one seen).
TXLINE_FIXTURE_ID=

# Solana devnet — leave blank to use simulated anchoring/verification
SOLANA_CLUSTER=devnet
SOLANA_RPC=https://api.devnet.solana.com
TXORACLE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
# Generate + fund:  solana-keygen new --outfile ./agent-key.json && solana airdrop 2 <pubkey> --url devnet
WALLET_KEYPAIR_PATH=./agent-key.json
